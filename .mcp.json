{
  "mcpServers": {
    "xdebug": {
      "command": "npx",
      "args": ["-y", "xdebug-mcp"],
      "env": { "XDEBUG_SOCKET_PATH": "/tmp/xdebug/site-wp-dev-1.sock" }
    },
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--viewport=1440x900",
        "--no-usage-statistics",
        "--no-performance-crux"
      ]
    }
  }
}
