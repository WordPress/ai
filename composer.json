{
  "name": "wordpress/ai",
  "description": "Experimental AI features for WordPress",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4",
    "ext-json": "*"
  },
  "require-dev": {
    "automattic/vipwpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0.0",
    "phpcompatibility/php-compatibility": "10.x-dev as 9.99.99",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpstan/phpstan": "^2.1",
    "php-stubs/wordpress-stubs": "^6.8",
    "slevomat/coding-standard": "^8.0",
    "wp-coding-standards/wpcs": "^3.2.0",
    "wp-phpunit/wp-phpunit": "^6.3",
    "wpackagist-plugin/plugin-check": "^1.6",
    "yoast/phpunit-polyfills": "^4.0.0"
  },
  "autoload": {
    "psr-4": {
      "WordPress\\AI\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WordPress\\AI\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "composer/installers": true
    },
    "platform": {
      "php": "7.4"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": [
        "wpackagist-plugin/*",
        "wpackagist-theme/*"
      ]
    }
  ],
  "extra": {
    "installer-paths": {
      "vendor/{$vendor}/{$name}/": [
        "wpackagist-plugin/plugin-check"
      ]
    }
  },
  "scripts": {
    "format": "phpcbf --standard=phpcs.xml.dist",
    "lint": "phpcs --standard=phpcs.xml.dist",
    "test": "phpunit",
    "stan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M"
  },
  "scripts-descriptions": {
    "format": "Automatically fix coding standards issues",
    "lint": "Check coding standards compliance",
    "test": "Run PHPUnit tests",
    "stan": "Run static analysis with PHPStan"
  }
}
