    "@wordpress/env": "^10.34.0",
    "@wordpress/eslint-plugin": "^22.20.0",
    "@wordpress/hooks": "^4.34.0",
    "@wordpress/i18n": "^6.7.0",
    "@wordpress/plugins": "^7.34.0",
    "@wordpress/prettier-config": "^4.34.0",
